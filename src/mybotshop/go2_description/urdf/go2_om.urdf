      <inertia ixx="1.0e-03" ixy="0.0" ixz="0.0" iyy="1.0e-03" iyz="0.0" izz="1.0e-03"/>
    </inertial>
  </link>
  <!-- end effector joint -->
  <joint name="end_effector_joint" type="fixed">
    <origin rpy="0 0 0" xyz="0.126 0.0 0.0"/>
    <parent link="link5"/>
    <child link="end_effector_link"/>
  </joint>
  <!-- end effector link -->
  <link name="end_effector_link">
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <box size="0.01 0.01 0.01"/>
      </geometry>
      <material name="red"/>
    </visual>
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="1.0e-03"/>
      <inertia ixx="1.0e-03" ixy="0.0" ixz="0.0" iyy="1.0e-03" iyz="0.0" izz="1.0e-03"/>
    </inertial>
  </link>
  <ros2_control name="open_manipulator_x_ros2_control" type="system">
    <hardware>
      <plugin>dynamixel_hardware/DynamixelHardware</plugin>
      <param name="usb_port">/dev/go2dynamixel</param>
      <param name="baud_rate">1000000</param>
      <!-- <param name="use_dummy">true</param> -->
    </hardware>
    <joint name="joint1">
      <param name="id">11</param>
      <command_interface name="position"/>
      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="joint2">
      <param name="id">12</param>
      <command_interface name="position"/>
      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="joint3">
      <param name="id">13</param>
      <command_interface name="position"/>
      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="joint4">
      <param name="id">14</param>
      <command_interface name="position"/>
      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="gripper">
      <param name="id">15</param>
      <command_interface name="position"/>
      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
  </ros2_control>
  <!-- Open Manipulator Add on -->
  <link name="front_top_mount"/>
  <joint name="front_top_mount_joint" type="fixed">
    <parent link="utlidar_lidar"/>
    <child link="front_top_mount"/>
    <origin rpy="3.14 0 3.14" xyz="0.15 0.0 -0.15"/>
  </joint>
  <!-- Open Manipulator Bracket -->
  <link name="open_manipulator_bracket">
    <visual>
      <geometry>
        <mesh filename="package://go2_description/meshes/3d_brackets/open_manipulator_combined_fixture.stl" scale="0.01 0.01 0.01"/>
      </geometry>
      <material name="dark_gray"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://go2_description/meshes/3d_brackets/open_manipulator_combined_fixture.stl" scale="0.01 0.01 0.01"/>
      </geometry>
    </collision>
  </link>
  <joint name="open_manipulator_bracket_joint" type="fixed">
    <parent link="front_top_mount"/>
    <child link="open_manipulator_bracket"/>
    <origin rpy="0 0 0" xyz="0.062 0 0.021"/>
  </joint>
  <joint name="open_manipulator_joint" type="fixed">
    <parent link="front_top_mount"/>
    <child link="link1"/>
    <origin rpy="0 0 0" xyz="0.0025 0 0.01"/>
  </joint>
  <!-- Open Manipulator Base Bracket -->
  <link name="open_manipulator_base_bracket">
    <visual>
      <geometry>
        <mesh filename="package://go2_description/meshes/3d_brackets/GO2_Openmanipulator_Base.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="dark_gray"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://go2_description/meshes/3d_brackets/GO2_Openmanipulator_Base.stl" scale="1 1 1"/>
      </geometry>
    </collision>
  </link>
  <joint name="open_manipulator_base_bracket_joint" type="fixed">
    <parent link="front_top_mount"/>
    <child link="open_manipulator_base_bracket"/>
    <origin rpy="0 0 1.5708" xyz="0.032 0.0 0.007"/>
  </joint>
</robot>
